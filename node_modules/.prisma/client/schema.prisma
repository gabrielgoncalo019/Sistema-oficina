// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  login     String   @unique
  password  String
  profile   String // "Administrador" ou "Operador"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          Int      @id @default(autoincrement())
  name        String
  companyName String?
  cpfCnpj     String?
  phone       String?
  whatsapp    String?
  address     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  budgets     Budget[]
  orders      Order[]
}

model Product {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  description   String
  quantity      Float          @default(0)
  minQuantity   Float          @default(0)
  unitPrice     Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  budgetItems   BudgetItem[]
  orderItems    OrderItem[]
  purchaseItems PurchaseItem[]
}

model Budget {
  id         Int          @id @default(autoincrement())
  number     Int          @unique
  clientId   Int
  client     Client       @relation(fields: [clientId], references: [id])
  status     String       @default("enviado") // enviado, aprovado, recusado
  validity   DateTime
  laborCost  Float        @default(0)
  totalValue Float        @default(0)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  items      BudgetItem[]
  order      Order?
}

model BudgetItem {
  id          Int      @id @default(autoincrement())
  budgetId    Int
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  totalPrice  Float    @default(0)
  type        String // "service" ou "product"
}

model Order {
  id             Int         @id @default(autoincrement())
  number         Int         @unique
  clientId       Int
  client         Client      @relation(fields: [clientId], references: [id])
  budgetId       Int?        @unique
  budget         Budget?     @relation(fields: [budgetId], references: [id])
  status         String      @default("aberta") // aberta, em_andamento, concluida, cancelada
  laborCost      Float       @default(0)
  totalValue     Float       @default(0)
  costValue      Float       @default(0) // Valor de custo
  profitValue    Float       @default(0) // Valor de lucro
  technicalNotes String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
  financial      Financial[]
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  costPrice   Float    @default(0) // Preço de custo
  totalPrice  Float    @default(0)
  type        String // "service" ou "product"
}

model Purchase {
  id         Int            @id @default(autoincrement())
  number     Int            @unique
  supplier   String?
  totalValue Float          @default(0)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  items      PurchaseItem[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
  unitPrice  Float
  totalPrice Float
}

model Financial {
  id           Int      @id @default(autoincrement())
  orderId      Int?
  order        Order?   @relation(fields: [orderId], references: [id])
  type         String // "receita" ou "despesa"
  description  String
  grossRevenue Float    @default(0) // Faturamento bruto
  totalCost    Float    @default(0) // Custo total
  netProfit    Float    @default(0) // Lucro líquido
  companyCash  Float    @default(0) // Caixa Empresa (60%)
  salaryCash   Float    @default(0) // Caixa Salarial (40%)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Settings {
  id              Int      @id @default(autoincrement())
  companyName     String   @default("Irmão Freios Pneumáticos")
  cnpj            String?
  address         String?
  phone           String?
  email           String?
  logo            String?
  signature       String?
  defaultMinStock Float    @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
